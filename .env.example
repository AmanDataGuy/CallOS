# ============================================================
# .env.example
# ------------------------------------------------------------
# Copy to .env and fill in the keys you have. CallOS runs
# locally with NO paid keys — only an LLM key is needed, and
# the loader picks whichever of the three below is present
# (see config.py: GOOGLE_API_KEY -> GROQ_API_KEY -> OPENAI_API_KEY).
# ============================================================

# ---- LLM providers (at least ONE required) -----------------
# Google AI Studio key (free tier): https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Groq key (free, very fast): https://console.groq.com/keys
GROQ_API_KEY=
# OpenAI key (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Set True to route Gemini through Vertex AI instead of AI Studio.
GOOGLE_GENAI_USE_VERTEXAI=False

# ---- GCP (only needed for `adk deploy` / Vertex AI) --------
GOOGLE_CLOUD_PROJECT=          # your GCP project id
GOOGLE_CLOUD_LOCATION=us-central1

# ---- Telephony / voice (paid — stubbed locally) ------------
# Twilio console: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
# Deepgram (STT): https://console.deepgram.com
DEEPGRAM_API_KEY=
# ElevenLabs (TTS): https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # default: Rachel — change at elevenlabs.io/voices

# ---- data layer --------------------------------------------
# Local default is SQLite (callos.db). In production set a
# PostgreSQL URL and config.py will use it instead.
DATABASE_URL=                  # e.g. postgresql://user:pass@host:5432/callos
SQLITE_PATH=callos.db          # local SQLite file path

# ---- cache -------------------------------------------------
# Local default is an in-process dict (see cache.py).
REDIS_URL=                     # e.g. redis://localhost:6379/0

# ---- observability (optional) ------------------------------
# Langfuse cloud: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
